# ─── Banco de dados ───────────────────────────────────────────────────────────
# Supabase (produção atual):
# DATABASE_URL=postgresql://postgres:<SENHA_URL_ENCODED>@db.<PROJECT>.supabase.co:5432/postgres?sslmode=require
#
# IMPORTANTE: caracteres especiais na senha devem ser URL-encoded
#   # → %23    / → %2F    & → %26    @ → %40
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_ID.supabase.co:5432/postgres?sslmode=require

# ─── Segurança ────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-em-producao-use-openssl-rand-hex-32

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Evolution API (WhatsApp) ─────────────────────────────────────────────────
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-chave-aqui

# ─── Observabilidade ─────────────────────────────────────────────────────────
# Sentry DSN — opcional. App sobe normalmente se ausente.
# SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── CORS ────────────────────────────────────────────────────────────────────
# Origens permitidas separadas por vírgula. OBRIGATÓRIO — app não sobe sem isso.
# Dev:  ALLOWED_ORIGINS=http://localhost:3000
# Prod: ALLOWED_ORIGINS=https://app.seudominio.com.br,https://painel.seudominio.com.br
ALLOWED_ORIGINS=http://localhost:3000

# ─── URLs públicas ────────────────────────────────────────────────────────────
# URL que a Evolution API usa para enviar webhooks de volta à API
WEBHOOK_BASE_URL=https://api.seudominio.com.br

# URL do frontend (painel + página de agendamento público)
FRONTEND_URL=https://app.seudominio.com.br

# ─── Bot (valores padrão já definidos em config.py) ──────────────────────────
# BOT_SESSION_TTL_MINUTES=30
# BOT_MAX_SLOTS_DISPLAYED=6
# BOT_FALLBACK_MAX_COUNT=3
# BOT_USE_BUTTONS=false

# ─── Políticas de agendamento ─────────────────────────────────────────────────
# APPOINTMENT_MIN_HOURS_BEFORE_CANCEL=2
# APPOINTMENT_MIN_HOURS_BEFORE_RESCHEDULE=2

# ─── Email transacional (Sprint I — adapter plugável) ────────────────────────
# EMAIL_PROVIDER escolhe o provider HTTP global: mailtrap (default) | sendgrid | smtp
# Railway bloqueia SMTP de saída (portas 25/465/587/2525) — em produção usar
# um provider HTTP. Se a credencial do provider escolhido estiver ausente,
# o envio cai no fallback SMTP (credencial do tenant ou SMTP_* abaixo).
EMAIL_PROVIDER=mailtrap

# Mailtrap HTTP API. Sandbox (dev/teste): preencher MAILTRAP_SANDBOX_INBOX_ID.
# Produção (Email Sending API): MAILTRAP_SANDBOX_INBOX_ID=0.
MAILTRAP_API_TOKEN=
MAILTRAP_SANDBOX_INBOX_ID=0

# SendGrid (produção): EMAIL_PROVIDER=sendgrid + API key abaixo.
SENDGRID_API_KEY=

# Remetente dos emails (usado por todos os providers)
SMTP_FROM_EMAIL=noreply@seudominio.com.br

# SMTP global (fallback — não funciona no Railway)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true

# ─── Dev/teste — NullProvider de pagamentos ───────────────────────────────────
# Simula o resultado de provider.refund() no NullProvider: success | error
# NULLPROVIDER_REFUND_OUTCOME=success
