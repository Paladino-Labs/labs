# ─── Banco de dados ───────────────────────────────────────────────────────────
# Supabase (produção atual):
# DATABASE_URL=postgresql://postgres:<SENHA_URL_ENCODED>@db.<PROJECT>.supabase.co:5432/postgres?sslmode=require
#
# IMPORTANTE: caracteres especiais na senha devem ser URL-encoded
#   # → %23    / → %2F    & → %26    @ → %40
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_ID.supabase.co:5432/postgres?sslmode=require

# ─── Segurança ────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-em-producao-use-openssl-rand-hex-32

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Evolution API (WhatsApp) ─────────────────────────────────────────────────
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-chave-aqui

# ─── URLs públicas ────────────────────────────────────────────────────────────
# URL que a Evolution API usa para enviar webhooks de volta à API
WEBHOOK_BASE_URL=https://api.seudominio.com.br

# URL do frontend (painel + página de agendamento público)
FRONTEND_URL=https://app.seudominio.com.br

# ─── Bot (valores padrão já definidos em config.py) ──────────────────────────
# BOT_SESSION_TTL_MINUTES=30
# BOT_MAX_SLOTS_DISPLAYED=6
# BOT_FALLBACK_MAX_COUNT=3
# BOT_USE_BUTTONS=false

# ─── Políticas de agendamento ─────────────────────────────────────────────────
# APPOINTMENT_MIN_HOURS_BEFORE_CANCEL=2
# APPOINTMENT_MIN_HOURS_BEFORE_RESCHEDULE=2
